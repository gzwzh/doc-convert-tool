/** app.wxss **/

/* 全局设计变量 (Design Tokens) - V2.0 Modern Clean */
page {
  /* 品牌色 */
  --primary-color: #2563EB;
  --primary-dark: #1E40AF;
  --primary-gradient: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  
  /* 功能色 */
  --success-color: #10B981;
  --warning-color: #F59E0B;
  --danger-color: #EF4444;
  
  /* 背景色 */
  --bg-color: #F1F5F9; /* 更冷淡的高级灰 */
  --surface-color: #FFFFFF;
  --surface-hover: #F8FAFC;
  
  /* 文本色 */
  --text-primary: #0F172A; /* 深蓝黑，比纯黑更有质感 */
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --text-inverse: #FFFFFF;

  /* 边框 */
  --border-color: #E2E8F0;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-full: 9999rpx;

  /* 阴影 - 更加弥散柔和 */
  --shadow-sm: 0 1rpx 2rpx 0 rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1), 0 2rpx 4rpx -1rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.05);
  --shadow-float: 0 20rpx 25rpx -5rpx rgba(0, 0, 0, 0.1), 0 10rpx 10rpx -5rpx rgba(0, 0, 0, 0.04);

  /* 全局样式重置 */
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx; /* TabBar spacing */
}

/* 通用组件类 */
.card {
  background: var(--surface-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-md);
  transition: all 0.2s ease;
}

.card:active {
  transform: scale(0.995);
  background: var(--surface-hover);
}

.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-full);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: translateY(1rpx);
}

.text-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
}

.text-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* Utility */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
