
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 80rpx;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  margin-bottom: -40rpx; /* Overlap with grid */
  position: relative;
  z-index: 0;
}

.category-icon {
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.category-icon-img {
  width: 64rpx;
  height: 64rpx;
}

.category-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1px;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* 2 columns for better readability */
  gap: 24rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
}

.tool-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: var(--shadow-float);
  transition: all 0.2s ease;
}

.tool-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 20rpx rgba(37, 99, 235, 0.15);
}

.tool-icon {
  margin-bottom: 24rpx;
  width: 100rpx;
  height: 100rpx;
  background: #F8FAFC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}
