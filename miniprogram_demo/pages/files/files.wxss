
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.3;
  filter: grayscale(100%);
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* List Styles */
.group {
  margin-bottom: 40rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  transition: all 0.2s ease;
}

.file-hover {
  transform: scale(0.99);
  background-color: #FAFAFA;
}

.file-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  background: #F3F4F6; /* Default */
}

/* Icon Variations */
.file-icon-wrapper.pdf {
  background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
  color: #DC2626;
}

.file-icon-wrapper.docx {
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  color: #2563EB;
}

.file-icon-wrapper.jpg {
  background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
  color: #16A34A;
}

.file-icon-text {
  font-size: 44rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.file-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-transform: uppercase;
  font-weight: 500;
}

.action-icon {
  font-size: 40rpx;
  color: #D1D5DB;
  padding: 0 10rpx;
  font-weight: bold;
}
