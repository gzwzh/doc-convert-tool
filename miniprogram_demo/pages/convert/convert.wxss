
/* pages/convert/convert.wxss */

.container {
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
}

/* 1. Page Header */
.page-header {
  margin-bottom: 60rpx;
  text-align: center;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  background: #EFF6FF;
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  margin-bottom: 24rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.header-tag:active {
  background: #DBEAFE;
  transform: scale(0.98);
}

.tag-arrow {
  margin-left: 12rpx;
  font-size: 18rpx;
  opacity: 0.6;
}

.header-title {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 2. Upload Zone */
.upload-zone {
  background: #FFFFFF;
  border: 4rpx dashed #CBD5E1;
  border-radius: 40rpx;
  height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  margin-bottom: 40rpx;
}

.upload-zone-hover {
  border-color: var(--primary-color);
  background: #F8FAFC;
  transform: scale(0.99);
}

.upload-circle-bg {
  width: 140rpx;
  height: 140rpx;
  background: #EFF6FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.upload-icon-img {
  width: 80rpx;
  height: 80rpx;
}

.upload-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.upload-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 3. Process & Result Card */
.process-card, .result-card {
  padding: 40rpx;
}

.file-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  background: #F8FAFC;
  padding: 24rpx;
  border-radius: var(--radius-md);
}

.file-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}

.file-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.file-size {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.close-btn {
  font-size: 32rpx;
  color: var(--text-tertiary);
  padding: 10rpx;
}

/* Success State */
.success-anim {
  width: 120rpx;
  height: 120rpx;
  background: #ECFDF5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.check-icon {
  font-size: 60rpx;
  color: #10B981;
}

.result-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.result-desc {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.btn-text {
  background: none;
  color: var(--text-secondary);
  font-size: 28rpx;
  margin-top: 24rpx;
}

/* 4. Advanced Settings */
.settings-section {
  margin-top: auto;
  padding-top: 40rpx;
}

.settings-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  transition: transform 0.3s;
}

.arrow.rotate {
  transform: rotate(180deg);
}

.settings-content {
  background: #F8FAFC;
  padding: 30rpx;
  border-radius: var(--radius-md);
  margin-top: 10rpx;
  animation: fadeIn 0.2s ease;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input-field {
  background: white;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1px solid var(--border-color);
  font-size: 26rpx;
  color: var(--text-primary);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
