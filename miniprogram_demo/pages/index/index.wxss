
.page-wrapper {
  background: var(--bg-color);
  min-height: 100vh;
  position: relative;
}

/* 1. Header Background */
.header-bg {
  height: 320rpx;
  background: var(--primary-gradient);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  padding: var(--spacing-lg) var(--spacing-lg) 0;
  position: absolute;
  top: 0;
  width: 100%;
  z-index: 0;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-top: 20rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.greeting-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  backdrop-filter: blur(10px);
}

/* 2. Main Content */
.main-content {
  position: relative;
  z-index: 1;
  padding: 180rpx var(--spacing-md) 120rpx; /* Push down to overlap header */
}

/* Hero Card */
.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-float);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.hero-btn {
  width: 100rpx;
  height: 100rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.4);
}

.hero-icon {
  font-size: 48rpx;
  color: #fff;
}

/* Sections */
.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* Tools Grid */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tool-icon-box {
  width: 110rpx;
  height: 110rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  transition: transform 0.2s;
}

.tool-icon-box:active {
  transform: scale(0.95);
}

.tool-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.tool-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
}

/* Recent Files List */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.file-icon-mini {
  width: 80rpx;
  height: 80rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.file-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.file-action-btn {
  padding: 10rpx;
  color: var(--text-tertiary);
}
