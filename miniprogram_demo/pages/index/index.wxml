<view class="page-wrapper">
  <!-- 1. Top Brand Header Background -->
  <view class="header-bg">
    <view class="header-content">
      <view class="greeting">
        <text class="greeting-text">DocFlow 助手</text>
        <view class="greeting-sub">高效处理您的文档</view>
      </view>
      <!-- Optional: User Avatar or Settings Icon -->
      <view class="header-icon">🔔</view>
    </view>
  </view>

  <!-- 2. Main Content Area (Overlaps Header) -->
  <view class="main-content">
    
    <!-- Hero Card: Main Action -->
    <view class="hero-card card" bindtap="onMainUpload">
      <view class="hero-info">
        <view class="hero-title">开始转换</view>
        <view class="hero-desc">支持 20+ 种格式互转</view>
      </view>
      <view class="hero-btn">
        <text class="hero-icon">+</text>
      </view>
    </view>

    <!-- Tools Categories Section -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">工具分类</text>
      </view>
      
      <view class="tools-grid">
        <view class="tool-item" wx:for="{{categories}}" wx:key="id" bindtap="onTapCategory" data-id="{{item.id}}">
          <view class="tool-icon-box" style="background: {{item.bg}}; color: {{item.color}}">
            <image src="{{item.icon}}" mode="aspectFit" class="tool-icon-img" />
          </view>
          <text class="tool-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- Recent Files Section -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">最近记录</text>
      </view>
      
      <view class="recent-list">
        <view class="recent-item card" wx:for="{{recentFiles}}" wx:key="id">
          <view class="file-icon-mini" wx:if="{{item.type === 'pdf'}}">📄</view>
          <view class="file-icon-mini" wx:elif="{{item.type === 'docx'}}">📝</view>
          <view class="file-icon-mini" wx:else>📁</view>
          
          <view class="file-info">
            <view class="file-name">{{item.name}}</view>
            <view class="file-date">{{item.date}}</view>
          </view>
          <view class="file-action-btn">⋮</view>
        </view>
      </view>
    </view>
    
  </view>
</view>